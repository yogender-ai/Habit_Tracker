# Render backend
APP_TIMEZONE=Asia/Kolkata
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Vercel/Vite frontend. Set this in Vercel Project Settings -> Environment Variables.
VITE_API_BASE_URL=
VITE_APP_TIMEZONE=Asia/Kolkata

# Neon primary and fallback databases. Put the real URLs in Render env vars.
DATABASE_URL_PRIMARY=postgresql://user:password@host-1.neon.tech/dbname?sslmode=require
DATABASE_URL_SECONDARY=postgresql://user:password@host-2.neon.tech/dbname?sslmode=require

# Firebase Admin for backend token verification
FIREBASE_PROJECT_ID=news-intel-d1bd3
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"news-intel-d1bd3"}

# Use true only for local API testing without Firebase.
ALLOW_DEV_AUTH=false

# Resend notifications
# Use a verified sender/domain from Resend, for example:
# RESEND_FROM_EMAIL=DayForge <noreply@yourdomain.com>
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=DayForge <noreply@yourdomain.com>
RESEND_REPLY_TO=you@example.com

# Any long random secret. Your cron job must send it as X-Cron-Secret.
NOTIFICATION_CRON_SECRET=replace-with-a-long-random-secret
