# Render backend
APP_TIMEZONE=Asia/Kolkata
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5000

# Neon primary and fallback databases. Put the real URLs in Render env vars.
DATABASE_URL_PRIMARY=postgresql://user:password@host-1.neon.tech/dbname?sslmode=require
DATABASE_URL_SECONDARY=postgresql://user:password@host-2.neon.tech/dbname?sslmode=require

# Firebase Admin for backend token verification
FIREBASE_PROJECT_ID=news-intel-d1bd3
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"news-intel-d1bd3"}

# Use true only for local API testing without Firebase.
ALLOW_DEV_AUTH=false
